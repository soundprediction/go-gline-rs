@@ -907,3 +940,85 @@
 // Baked nei modelli count_lstm_fixed (output shape fisso [MAX_COUNT, M, H]).
 #[allow(dead_code)]
 const MAX_COUNT: usize = 20;
+
+/// PATCH (go-gline-rs): decode a `json_structures` task into an [`ExtractedStructure`].
+///
+/// Reuses the entity span-score tensor `scores[instance, start, width, field]`. Each
+/// count index is one object instance; each field (label column) is span-extracted from
+/// the text. dtype `Str` takes the first span in (start,width) order (matching Python's
+/// `spans[0]`); dtype `List` takes all spans, confidence-sorted with greedy char-overlap
+/// removal (matching Python's `_format_spans`). Choice restriction is NOT applied — the
+/// engine has no schema-prefix span scores — so choice fields are span-extracted too.
+fn decode_structure(
+    task_map: &crate::processor::TaskMapping,
+    scores: &ndarray::ArrayD<f32>,
+    record: &crate::processor::ProcessedRecord,
+    text: &str,
+    pred_count: usize,
+    threshold: f32,
+    max_width: usize,
+    num_words: usize,
+) -> ExtractedStructure {
+    let mut instances = Vec::new();
+    for c_idx in 0..pred_count {
+        let mut obj = serde_json::Map::new();
+        let mut any = false;
+        for (m, field_name) in task_map.labels.iter().enumerate() {
+            // Candidate spans for (instance c_idx, field m), in (start, width) order.
+            let mut cands: Vec<(f32, usize, usize, String)> = Vec::new(); // (score, char_start, char_end, text)
+            for start in 0..num_words {
+                for width_idx in 0..max_width {
+                    let end = std::cmp::min(start + width_idx + 1, num_words);
+                    let prob = scores[[c_idx, start, width_idx, m]];
+                    if prob > threshold {
+                        let char_start = record.word_to_char_maps[start].0;
+                        let char_end = record.word_to_char_maps[end - 1].1;
+                        if char_start <= char_end && char_end <= text.len() {
+                            let t = text[char_start..char_end].trim().to_string();
+                            if !t.is_empty() {
+                                cands.push((prob, char_start, char_end, t));
+                            }
+                        }
+                    }
+                }
+            }
+
+            let dtype = task_map.field_dtypes.get(m).copied().unwrap_or(Dtype::List);
+            match dtype {
+                Dtype::Str => {
+                    if let Some((_, _, _, t)) = cands.first() {
+                        obj.insert(field_name.clone(), serde_json::Value::String(t.clone()));
+                        any = true;
+                    } else {
+                        obj.insert(field_name.clone(), serde_json::Value::Null);
+                    }
+                }
+                Dtype::List => {
+                    cands.sort_by(|a, b| b.0.partial_cmp(&a.0).unwrap_or(std::cmp::Ordering::Equal));
+                    let mut selected: Vec<(usize, usize, String)> = Vec::new();
+                    for (_s, cs, ce, t) in cands {
+                        let overlap = selected.iter().any(|(s, e, _)| !(ce <= *s || cs >= *e));
+                        if !overlap {
+                            selected.push((cs, ce, t));
+                        }
+                    }
+                    let arr: Vec<serde_json::Value> = selected
+                        .into_iter()
+                        .map(|(_, _, t)| serde_json::Value::String(t))
+                        .collect();
+                    if !arr.is_empty() {
+                        any = true;
+                    }
+                    obj.insert(field_name.clone(), serde_json::Value::Array(arr));
+                }
+            }
+        }
+        if any {
+            instances.push(serde_json::Value::Object(obj));
+        }
+    }
+    ExtractedStructure {
+        name: task_map.task_name.clone(),
+        instances,
+    }
+}
